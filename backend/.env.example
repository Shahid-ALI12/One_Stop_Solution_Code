# ───────────────────────────────────────────────────────────────
# One Stop Solution — Backend environment template
# Copy this file to `.env` and fill in real values.
# NEVER commit your real .env to git.
# ───────────────────────────────────────────────────────────────

# ── App config ────────────────────────────────────────────────
APP_NAME=One Stop Solution API
APP_VERSION=0.1.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ── Security ──────────────────────────────────────────────────
# Generate a long random string for production, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-string

# ── Database ──────────────────────────────────────────────────
# SQLite (default, dev):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/onestop

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Default admin (used by /seed endpoint on first run) ──────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_DISPLAY_NAME=Site Administrator

# ── SMTP (for enquiry + consultation notifications to admin) ─
# When SMTP_HOST is empty, email sending is silently skipped
# (useful for local dev without an SMTP server).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@onestopsolution.com
ADMIN_NOTIFY_EMAIL=admin@onestopsolution.com

# ── WhatsApp / Twilio (for enquiry notifications) ────────────
# When TWILIO_WHATSAPP_FROM is empty, WhatsApp sending is skipped.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_WHATSAPP_TO=

# ── Visit tracking (IP → country) ────────────────────────────
# Use the free ipapi.co service by default (no key needed, 30k/month).
# Set IPAPI_TOKEN to use the paid tier with higher rate limits.
IPAPI_TOKEN=

# ── File uploads ─────────────────────────────────────────────
# Local directory where uploaded portfolio images / resource PDFs are stored.
UPLOAD_DIR=uploads
# Max upload size in bytes (default 10 MB).
UPLOAD_MAX_BYTES=10485760
# Comma-separated allowed extensions per category.
UPLOAD_PORTFOLIO_EXT=jpg,jpeg,png,webp,gif
UPLOAD_RESOURCE_EXT=pdf,doc,docx,xls,xlsx,ppt,pptx,zip,txt
# Public base URL for serving uploaded files. Empty = same-origin (/uploads/...).
# For production, set this to your CDN/static host, e.g. https://cdn.example.com
UPLOAD_PUBLIC_BASE=
